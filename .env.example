# Copy to .env and fill in your camera's RTSP URL.
# docker compose automatically reads .env in this directory.

# Required. Find this in your camera's app/manual. Common formats:
#   Reolink:   rtsp://user:pass@192.168.1.50:554/h264Preview_01_main
#   Hikvision: rtsp://user:pass@192.168.1.50:554/Streaming/Channels/101
#   Dahua:     rtsp://user:pass@192.168.1.50:554/cam/realmonitor?channel=1&subtype=0
#   Amcrest:   rtsp://user:pass@192.168.1.50:554/cam/realmonitor?channel=1&subtype=0
#   ONVIF/std: rtsp://user:pass@192.168.1.50:554/stream1
CAMERA_RTSP_URL=rtsp://user:pass@192.168.1.50:554/stream1

# Optional. Enables true WebRTC (lowest latency) in bridge networking.
# Set to your home server's LAN IP and the WebRTC port. If left unset, camview
# still works over :8080 using MSE (~1s latency).
# Find your server's LAN IP with: ip route get 1 | awk '{print $7; exit}'
# WEBRTC_CANDIDATE=192.168.1.10:8555

# Optional. "h264" (default) transcodes the feed so any browser can play it.
# Set to "off" to pass the camera through unchanged — only do this if the camera
# already streams H.264 (e.g. you pointed CAMERA_RTSP_URL at its sub-stream).
# TRANSCODE=h264

# Optional. Offload the H.264 transcode to a GPU instead of the CPU. Leave unset
# for software encoding. Requires the matching GPU passthrough in compose.
# Values: vaapi (Intel/AMD), cuda (NVIDIA), qsv, ...
# HWACCEL=vaapi
